{
  "name": "qrcode",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "rm -rf docs; run-p type-check \"build-only {@}\" -- && cp docs/index.html docs/404.html",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "vue": "^3.5.14",
    "vue-router": "^4.5.1",
    "@tailwindcss/vite": "^4.1.7",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.1.7"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.1",
    "@types/node": "^22.15.19",
    "@types/qrcode": "^1.5.5",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/tsconfig": "^0.7.0",
    "daisyui": "^5.0.35",
    "eslint": "^9.27.0",
    "eslint-plugin-vue": "~10.1.0",
    "jiti": "^2.4.2",
    "npm-run-all2": "^8.0.2",
    "prettier": "3.5.3",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.0.0",
    "vite-plugin-vue-devtools": "^7.7.6",
    "vue-tsc": "^2.2.10"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide"
  ]
}
