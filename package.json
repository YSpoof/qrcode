{
  "name": "qrencode",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo '' && husky",
    "precommit": "lint-staged",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "predeploy": "pnpm run build",
    "deploy": "gh-pages -d build --nojekyll"
  },
  "dependencies": {
    "dexie": "^4.4.2",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.8.0",
    "@types/qrcode": "^1.5.6",
    "daisyui": "^5.5.19",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.50.0",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.13"
  },
  "lint-staged": {
    "*.{json,ts,js,svelte}": "oxfmt"
  }
}
